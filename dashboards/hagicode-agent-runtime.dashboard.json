{
  "version": 8,
  "title": "HagiCode Agent Runtime",
  "description": "OpenObserve dashboard for agent lifecycle health, tool outcomes, normalized error classes, and shared ACP pool pressure.",
  "tabs": [
    {
      "tabId": "default",
      "name": "Agent Runtime",
      "panels": [
        {
          "id": "1",
          "type": "line",
          "title": "Agent Lifecycle Rate by Outcome",
          "description": "Agent starts and terminal outcomes grouped by normalized agent name.",
          "config": {
            "show_legends": true,
            "legends_position": null,
            "base_map": {
              "type": "osm"
            },
            "map_view": {
              "zoom": 1,
              "lat": 0,
              "lng": 0
            }
          },
          "queryType": "promql",
          "queries": [
            {
              "query": "topk(12, sum by (agent_name, outcome) (rate(pcode_agent_lifecycle[5m])))",
              "customQuery": true,
              "fields": {
                "stream": "pcode_agent_lifecycle",
                "stream_type": "metrics",
                "x": [],
                "y": [],
                "z": [],
                "filter": {
                  "type": "list",
                  "values": [],
                  "logicalOperator": "AND",
                  "filterType": "list"
                }
              },
              "config": {
                "promql_legend": "{agent_name} {outcome}",
                "layer_type": "scatter",
                "weight_fixed": 1
              }
            }
          ],
          "layout": {
            "x": 0,
            "y": 0,
            "w": 96,
            "h": 14,
            "i": 1
          }
        },
        {
          "id": "2",
          "type": "line",
          "title": "Agent Failure Rate by Agent",
          "description": "Terminal failure and cancellation rate per agent, excluding the non-terminal start events.",
          "config": {
            "show_legends": true,
            "legends_position": null,
            "base_map": {
              "type": "osm"
            },
            "map_view": {
              "zoom": 1,
              "lat": 0,
              "lng": 0
            }
          },
          "queryType": "promql",
          "queries": [
            {
              "query": "100 * sum by (agent_name) (rate(pcode_agent_lifecycle{outcome=~'failure|cancelled'}[5m])) / clamp_min(sum by (agent_name) (rate(pcode_agent_lifecycle{outcome=~'success|failure|cancelled'}[5m])), 0.001)",
              "customQuery": true,
              "fields": {
                "stream": "pcode_agent_lifecycle",
                "stream_type": "metrics",
                "x": [],
                "y": [],
                "z": [],
                "filter": {
                  "type": "list",
                  "values": [],
                  "logicalOperator": "AND",
                  "filterType": "list"
                }
              },
              "config": {
                "promql_legend": "{agent_name}",
                "layer_type": "scatter",
                "weight_fixed": 1
              }
            }
          ],
          "layout": {
            "x": 96,
            "y": 0,
            "w": 96,
            "h": 14,
            "i": 2
          }
        },
        {
          "id": "3",
          "type": "line",
