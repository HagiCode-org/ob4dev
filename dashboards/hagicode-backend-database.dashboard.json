          "queryType": "promql",
          "queries": [
            {
              "query": "topk(10, sum by (db_collection_name, db_operation_name) (rate(pcode_database_command_duration_sum[5m])) / clamp_min(sum by (db_collection_name, db_operation_name) (rate(pcode_database_command_duration_count[5m])), 0.001))",
