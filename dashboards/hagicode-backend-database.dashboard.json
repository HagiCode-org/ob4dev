{
  "version": 8,
  "title": "HagiCode Backend Database",
  "description": "OpenObserve dashboard for EF Core command latency, failures, and the busiest collections.",
  "tabs": [
    {
      "tabId": "default",
      "name": "Database",
      "panels": [
        {
          "id": "1",
          "type": "line",
          "title": "Database Average Latency",
          "description": "Average latency for EF Core command execution grouped by provider and operation.",
          "config": {
            "show_legends": true,
            "legends_position": null,
            "base_map": {
              "type": "osm"
            },
            "map_view": {
              "zoom": 1,
              "lat": 0,
              "lng": 0
            },
            "unit": "ms"
          },
          "queryType": "promql",
          "queries": [
            {
              "query": "topk(8, sum by (db_system, db_operation_name) (rate(pcode_database_command_duration_sum[5m])) / sum by (db_system, db_operation_name) (rate(pcode_database_command_duration_count[5m])))",
              "customQuery": true,
              "fields": {
                "stream": "pcode_database_command_duration",
                "stream_type": "metrics",
                "x": [],
                "y": [],
                "z": [],
                "filter": {
                  "type": "list",
                  "values": [],
                  "logicalOperator": "AND",
                  "filterType": "list"
                }
              },
              "config": {
                "promql_legend": "{db_system} {db_operation_name}",
                "layer_type": "scatter",
                "weight_fixed": 1
              }
            }
          ],
          "layout": {
            "x": 0,
            "y": 0,
            "w": 96,
            "h": 14,
            "i": 1
          }
        },
        {
          "id": "2",
          "type": "line",
          "title": "Database Errors",
