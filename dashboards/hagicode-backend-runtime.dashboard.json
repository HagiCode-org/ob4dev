{
  "version": 8,
  "title": "HagiCode Backend Runtime",
  "description": "OpenObserve dashboard for .NET runtime health, memory usage, thread-pool pressure, and GC behavior.",
  "tabs": [
    {
      "tabId": "default",
      "name": "Runtime",
      "panels": [
        {
          "id": "1",
          "type": "line",
          "title": ".NET Working Set",
          "description": "Resident memory used by the current process.",
          "config": {
            "show_legends": true,
            "legends_position": null,
            "base_map": {
              "type": "osm"
            },
            "map_view": {
              "zoom": 1,
              "lat": 0,
              "lng": 0
            },
            "unit": "bytes"
          },
          "queryType": "promql",
          "queries": [
            {
              "query": "dotnet_process_memory_working_set",
              "customQuery": true,
              "fields": {
                "stream": "dotnet_process_memory_working_set",
                "stream_type": "metrics",
                "x": [],
                "y": [],
                "z": [],
                "filter": {
                  "type": "list",
                  "values": [],
                  "logicalOperator": "AND",
                  "filterType": "list"
                }
              },
              "config": {
                "promql_legend": "working set",
                "layer_type": "scatter",
                "weight_fixed": 1
              }
            }
          ],
          "layout": {
            "x": 0,
            "y": 0,
            "w": 96,
            "h": 14,
            "i": 1
          }
        },
        {
          "id": "2",
          "type": "line",
          "title": "GC Heap and Committed Memory",
          "description": "Managed heap size after the last collection and the committed GC memory footprint.",
          "config": {
            "show_legends": true,
            "legends_position": null,
            "base_map": {
              "type": "osm"
            },
            "map_view": {
              "zoom": 1,
              "lat": 0,
              "lng": 0
            },
            "unit": "bytes"
          },
          "queryType": "promql",
          "queries": [
            {
              "query": "sum(dotnet_gc_last_collection_heap_size)",
              "customQuery": true,
              "fields": {
                "stream": "dotnet_gc_last_collection_heap_size",
                "stream_type": "metrics",
                "x": [],
                "y": [],
                "z": [],
                "filter": {
                  "type": "list",
                  "values": [],
                  "logicalOperator": "AND",
                  "filterType": "list"
                }
              },
              "config": {
                "promql_legend": "gc heap size",
                "layer_type": "scatter",
                "weight_fixed": 1
              }
            },
            {
              "query": "dotnet_gc_last_collection_memory_committed_size",
              "customQuery": true,
              "fields": {
                "stream": "dotnet_gc_last_collection_memory_committed_size",
                "stream_type": "metrics",
                "x": [],
                "y": [],
                "z": [],
                "filter": {
                  "type": "list",
                  "values": [],
                  "logicalOperator": "AND",
                  "filterType": "list"
                }
              },
              "config": {
                "promql_legend": "gc committed",
                "layer_type": "scatter",
                "weight_fixed": 1
              }
            }
          ],
          "layout": {
            "x": 96,
            "y": 0,
            "w": 96,
            "h": 14,
            "i": 2
          }
        },
        {
          "id": "3",
          "type": "line",
          "title": "Thread Pool Queue Length",
